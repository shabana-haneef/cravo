{
  "autoCancelUnconfirmedMins": 45,
  "autoCompleteDeliveredDays": 7,
  "allowCustomerCancellation": true,
  "customerCancellationWindowMins": 30,
  "allowedTransitions": {
    "PLACED": [
      "CONFIRMED",
      "CANCELLED"
    ],
    "CONFIRMED": [
      "PREPARING"
    ],
    "PREPARING": [
      "READY_FOR_PICKUP",
      "OUT_FOR_DELIVERY"
    ],
