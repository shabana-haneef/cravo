generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  isEmailVerified    Boolean             @default(false)
  lastLoginAt        DateTime?
  passwordHash       String?
  googleId           String?             @unique
  status             UserStatus          @default(ACTIVE)
  role               UserRole            @default(CUSTOMER)
  addresses          Address[]
  cart               Cart?
  emailVerifications EmailVerification[]
  notifications      Notification[]
  orders             Order[]
  passwordResets     PasswordReset[]
  profile            Profile?
  refreshTokens      RefreshToken[]
  seller             Seller?
  wishlist           WishlistItem[]

  @@index([email])
  @@index([status])
}

model Seller {
  id                 String           @id @default(cuid())
  userId             String           @unique
  bio                String?
  averageRating      Float            @default(0.0)
  totalReviews       Int              @default(0)
  status             SellerStatus     @default(PENDING)
  rejectionReason    String?
  approvedAt         DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  pickupAddress      String?
  pickupCity         String?
  pickupLocationName String?
  pickupPhone        String?
  pickupPincode      String?
  pickupState        String?
  advertisements     Advertisement[]
  campaigns          Campaign[]
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents          SellerDocument[]
  shop               Shop?
}

model Shop {
  id                String       @id @default(cuid())
  sellerId          String       @unique
  name              String
  slug              String       @unique
  description       String?
  logoUrl           String?
  logoPublicId      String?
  bannerUrl         String?
  bannerPublicId    String?
  shopType          ShopType
  deliveryRadiusKm  Int          @default(5)
  isPickupEnabled   Boolean      @default(true)
  isDeliveryEnabled Boolean      @default(true)
  status            ShopStatus   @default(ACTIVE)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  carts             Cart[]
  orders            Order[]
  products          Product[]
  campaigns         Campaign[]
  seller            Seller       @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  timings           ShopTiming[]

  @@index([slug])
  @@index([sellerId])
  @@index([status])
}

model ShopTiming {
  id        String    @id @default(cuid())
  shopId    String
  dayOfWeek DayOfWeek
  openTime  String?
  closeTime String?
  isClosed  Boolean   @default(false)
  shop      Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, dayOfWeek])
}

model SellerDocument {
  id        String             @id @default(cuid())
  sellerId  String
  type      SellerDocumentType
  fileUrl   String
  publicId  String
  createdAt DateTime           @default(now())
  seller    Seller             @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId])
}

model Profile {
  id          String    @id @default(cuid())
  userId      String    @unique
  fullName    String?
  avatar      String?
  phone       String?
  dateOfBirth DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Address {
  id           String       @id @default(cuid())
  userId       String
  label        AddressLabel @default(HOME)
  fullName     String
  phone        String
  addressLine1 String
  addressLine2 String?
  city         String
  district     String?
  state        String
  postalCode   String
  latitude     Float?
  longitude    Float?
  isDefault    Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders       Order[]

  @@index([userId])
}

model EmailVerification {
  id        String   @id @default(cuid())
  userId    String
  otpHash   String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  otpHash   String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model Category {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique
  imageUrl      String?
  imagePublicId String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  products      Product[]
}

model Product {
  id                 String           @id @default(cuid())
  shopId             String
  categoryId         String
  name               String
  slug               String           @unique
  shortDescription   String?
  description        String?
  features           String[]         @default([])
  tags               String[]         @default([])
  status             ProductStatus    @default(PENDING_APPROVAL)
  rejectionReason    String?
  isFeatured         Boolean          @default(false)
  averageRating      Float            @default(0.0)
  totalReviews       Int              @default(0)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  ingredients        String           @default("Not specified")
  weight             Float?
  declaredValue      Float?
  labelImagePublicId String?
  labelImageUrl      String?
  cartItems          CartItem[]
  orderItems         OrderItem[]
  category           Category         @relation(fields: [categoryId], references: [id])
  shop               Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  images             ProductImage[]
  variants           ProductVariant[]
  wishlistedBy       WishlistItem[]

  @@index([shopId])
  @@index([categoryId])
  @@index([status])
  @@index([slug])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  imageUrl  String
  publicId  String
  sortOrder Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id             String      @id @default(cuid())
  productId      String
  name           String
  sku            String      @unique
  price          Float
  compareAtPrice Float?
  isActive       Boolean     @default(true)
  cartItems      CartItem[]
  inventory      Inventory?
  orderItems     OrderItem[]
  product        Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Inventory {
  id                String                 @id @default(cuid())
  productVariantId  String                 @unique
  availableStock    Int                    @default(0)
  reservedStock     Int                    @default(0)
  lowStockThreshold Int                    @default(5)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  productVariant    ProductVariant         @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  transactions      InventoryTransaction[]
}

model InventoryTransaction {
  id            String          @id @default(cuid())
  inventoryId   String
  type          TransactionType
  quantity      Int
  previousStock Int
  newStock      Int
  reason        String?
  createdBy     String?
  createdAt     DateTime        @default(now())
  inventory     Inventory       @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  @@index([inventoryId])
  @@index([createdAt])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  shopId    String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  shop      Shop?      @relation(fields: [shopId], references: [id])
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
}

model CartItem {
  id               String         @id @default(cuid())
  cartId           String
  productId        String
  productVariantId String
  quantity         Int
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  cart             Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product          Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)

  @@unique([cartId, productVariantId])
}

model Order {
  id                  String      @id @default(cuid())
  orderNumber         String      @unique
  customerId          String
  shopId              String
  addressId           String
  subtotal            Float
  deliveryCharge      Float
  discount            Float       @default(0.0)
  grandTotal          Float
  status              OrderStatus @default(PENDING_PAYMENT)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  awbNumber           String?
  delhiveryShipmentId String?
  pickupRequested     Boolean     @default(false)
  shipmentCreated     Boolean     @default(false)
  shipmentCreatedAt   DateTime?
  shipmentLogs        Json        @default("[]")
  shippingLabelUrl    String?
  trackingStatus      String      @default("pending")
  delivery            Delivery?
  address             Address     @relation(fields: [addressId], references: [id])
  customer            User        @relation(fields: [customerId], references: [id])
  shop                Shop        @relation(fields: [shopId], references: [id])
  items               OrderItem[]
  payments            Payment[]

  @@index([customerId])
  @@index([shopId])
  @@index([orderNumber])
  @@index([status])
}

model OrderItem {
  id               String         @id @default(cuid())
  orderId          String
  productId        String
  productVariantId String
  quantity         Int
  unitPrice        Float
  totalPrice       Float
  order            Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product          Product        @relation(fields: [productId], references: [id])
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])
}

model Payment {
  id                String        @id @default(cuid())
  orderId           String
  razorpayOrderId   String        @unique
  razorpayPaymentId String?       @unique
  razorpaySignature String?
  amount            Float
  status            PaymentStatus @default(PENDING)
  createdAt         DateTime      @default(now())
  order             Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Delivery {
  id                    String                  @id @default(cuid())
  orderId               String                  @unique
  trackingNumber        String?                 @unique
  delhiveryShipmentId   String?
  courierPartner        CourierPartner          @default(DELHIVERY)
  status                DeliveryStatus          @default(PENDING)
  estimatedDeliveryDate DateTime?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  order                 Order                   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  events                DeliveryTrackingEvent[]
}

model DeliveryTrackingEvent {
  id          String         @id @default(cuid())
  deliveryId  String
  status      DeliveryStatus
  description String?
  eventTime   DateTime       @default(now())
  createdAt   DateTime       @default(now())
  delivery    Delivery       @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@index([deliveryId])
}

model AdPackage {
  id             String          @id @default(cuid())
  name           String
  price          Float
  durationDays   Int
  features       String[]        @default([])
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  advertisements Advertisement[]
}

model Advertisement {
  id              String     @id @default(cuid())
  title           String
  imageUrl        String
  targetUrl       String
  sellerId        String?
  packageId       String?
  status          AdStatus   @default(PENDING_APPROVAL)
  rejectionReason String?
  startDate       DateTime?
  endDate         DateTime?
  views           Int        @default(0)
  clicks          Int        @default(0)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  payment         AdPayment?
  package         AdPackage? @relation(fields: [packageId], references: [id])
  seller          Seller?    @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([sellerId])
}

model AdPayment {
  id                String        @id @default(cuid())
  advertisementId   String        @unique
  razorpayOrderId   String        @unique
  razorpayPaymentId String?       @unique
  razorpaySignature String?
  amount            Float
  status            PaymentStatus @default(PENDING)
  createdAt         DateTime      @default(now())
  advertisement     Advertisement @relation(fields: [advertisementId], references: [id], onDelete: Cascade)
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

model AuditLog {
  id            String   @id @default(cuid())
  targetType    String?
  targetId      String?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())
  actionType    String
  actorEmail    String
  actorId       String
  actorRole     String
  endpoint      String?
  requestMethod String?
  status        String   @default("SUCCESS")
  targetName    String?

  @@index([actorId])
  @@index([actionType])
  @@index([createdAt])
}

model IntegrationLog {
  id        String   @id
  service   String
  event     String
  status    String
  timestamp DateTime @default(now())

  @@index([service])
  @@index([timestamp])
}

enum UserRole {
  CUSTOMER
  SELLER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum AddressLabel {
  HOME
  OFFICE
  OTHER
}

enum SellerStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum SellerDocumentType {
  ID_PROOF
  ADDRESS_PROOF
  SHOP_IMAGE
  FSSAI_LICENSE
}

enum ShopType {
  HOME_MADE
  FARMER
  BAKERY
  GROCERY
  FISH_SELLER
  MEAT_SELLER
  LOCAL_SHOP
  OTHER
}

enum ShopStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum TransactionType {
  STOCK_IN
  STOCK_OUT
  ORDER_RESERVED
  ORDER_RELEASED
  ORDER_COMPLETED
  MANUAL_ADJUSTMENT
}

enum ProductStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  ARCHIVED
}

enum NotificationType {
  ORDER_PLACED
  ORDER_STATUS_UPDATED
  ORDER_CANCELLED
  SELLER_APPROVED
  SELLER_REJECTED
  PRODUCT_APPROVED
  PRODUCT_REJECTED
}

enum OrderStatus {
  PENDING_PAYMENT
  PLACED
  CONFIRMED
  PREPARING
  READY_FOR_PICKUP
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum DeliveryStatus {
  PENDING
  BOOKED
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
  RETURNED
  CANCELLED
}

enum CourierPartner {
  DELHIVERY
  OTHER
}

enum AdStatus {
  PENDING_PAYMENT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  ACTIVE
  EXPIRED
}

model Campaign {
  id               String         @id @default(cuid())
  sellerId         String
  shopId           String
  name             String
  type             CampaignType
  status           CampaignStatus @default(DRAFT)
  bannerUrl        String?
  bannerPublicId   String?
  destinationUrl   String?
  targetProductIds String[]       @default([])
  budget           Float
  startDate        DateTime?
  endDate          DateTime?
  rejectionReason  String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  seller    Seller                  @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  shop      Shop                    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  payment   CampaignPayment?
  analytics CampaignAnalytics?
  history   CampaignStatusHistory[]

  @@index([sellerId])
  @@index([shopId])
  @@index([status])
}

model CampaignAnalytics {
  id          String   @id @default(cuid())
  campaignId  String   @unique
  impressions Int      @default(0)
  clicks      Int      @default(0)
  spend       Float    @default(0.0)
  updatedAt   DateTime @updatedAt
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model CampaignPayment {
  id                String        @id @default(cuid())
  campaignId        String        @unique
  razorpayOrderId   String        @unique
  razorpayPaymentId String?       @unique
  razorpaySignature String?
  amount            Float
  status            PaymentStatus @default(PENDING)
  createdAt         DateTime      @default(now())
  campaign          Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model CampaignStatusHistory {
  id         String         @id @default(cuid())
  campaignId String
  status     CampaignStatus
  reason     String?
  changedBy  String
  createdAt  DateTime       @default(now())
  campaign   Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
}

enum CampaignType {
  PRODUCT_PROMOTION
  STOREWIDE_OFFER
  DISCOUNT_CAMPAIGN
  FLASH_SALE
}

enum CampaignStatus {
  DRAFT
  PENDING_PAYMENT
  PENDING_APPROVAL
  APPROVED
  ACTIVE
  PAUSED
  COMPLETED
  REJECTED
  CANCELLED
}
